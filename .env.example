# Pomodoro Nuxt - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ===========================================
# Frontend (apps/web/.env)
# ===========================================

# API Configuration
NUXT_PUBLIC_API_BASE=http://localhost:8787

# Push Notifications (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Production API URL (uncomment when deploying)
# NUXT_PUBLIC_API_BASE=https://pomodoro.azlab.dev.br

# ===========================================
# API (apps/api/.env or wrangler secrets)
# ===========================================

# GitHub OAuth (set via wrangler secret put)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT/Better Auth Secret (MUST be set via wrangler secret put)
# BETTER_AUTH_SECRET=your_random_secret_key_min_32_chars

# D1 Database ID (configure in wrangler.toml)
# D1_DATABASE_ID=your_d1_database_id

# KV Namespace ID (configure in wrangler.toml)
# KV_NAMESPACE_ID=your_kv_namespace_id
