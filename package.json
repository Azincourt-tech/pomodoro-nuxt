{
	"name": "pomodoro-nuxt",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"dev": "nuxt dev",
		"build": "nuxt build",
		"preview": "nuxt preview",
		"generate": "nuxt generate",
		"lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx",
		"lint:fix": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
		"format": "prettier --write \"**/*.{vue,js,ts,jsx,tsx,css,scss,json,md}\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@nuxtjs/i18n": "^9.5.6",
		"@pinia/nuxt": "^0.9.0",
		"nuxt": "^3.15.0",
		"pinia": "^2.3.0",
		"vue": "^3.5.0"
	},
	"devDependencies": {
		"@nuxt/eslint-config": "^1.15.2",
		"@nuxt/test-utils": "^4.0.0",
		"@nuxtjs/tailwindcss": "^6.13.0",
		"@vue/test-utils": "^2.4.6",
		"daisyui": "^4.12.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"happy-dom": "^20.8.9",
		"prettier": "^3.8.1",
		"tailwindcss": "^3.4.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.2"
	}
}
