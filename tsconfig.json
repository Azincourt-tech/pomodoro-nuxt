{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"jsx": "preserve",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"lib": ["ESNext", "DOM"],
		"skipLibCheck": true,
		"paths": {
			"~/*": ["./*"],
			"@/*": ["./*"]
		},
		"types": ["@pinia/nuxt"]
	},
	"exclude": ["node_modules", ".nuxt", "dist"]
}
