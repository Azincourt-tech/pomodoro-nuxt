name = "pomodoro-api"
main = "src/index.ts"
compatibility_date = "2024-11-01"
compatibility_flags = ["nodejs_compat"]

[observability]
enabled = true

[[d1_databases]]
binding = "DB"
database_name = "pomodoro-db"
database_id = "SEU_DATABASE_ID_AQUI"

[[kv_namespaces]]
binding = "KV"
id = "SEU_KV_ID_AQUI"

[vars]
BETTER_AUTH_URL = "http://localhost:8787"
# GitHub OAuth - configure via: wrangler secret put GITHUB_CLIENT_ID
# GITHUB_CLIENT_ID = ""
# GITHUB_CLIENT_SECRET = ""

# IMPORTANT: Set BETTER_AUTH_SECRET via wrangler secret put BETTER_AUTH_SECRET
