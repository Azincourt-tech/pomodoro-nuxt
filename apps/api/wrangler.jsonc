{
  "name": "pomodoro-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pomodoro-db",
      "database_id": "{{D1_DATABASE_ID}}"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "{{KV_NAMESPACE_ID}}"
    }
  ],
  "vars": {
    "BETTER_AUTH_URL": "{{BETTER_AUTH_URL}}"
  }
}
