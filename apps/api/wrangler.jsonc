{
  "name": "pomodoro-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pomodoro-db",
      "database_id": "__D1_DATABASE_ID__"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "__KV_NAMESPACE_ID__"
    }
  ],
  "vars": {
    "BETTER_AUTH_URL": "__BETTER_AUTH_URL__"
  }
}
